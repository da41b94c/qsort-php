{
	"name": "da41b94c/qsort-php",
	"description": "Educational quick sort implementations for PHP with optional duplicate removal.",
	"type": "library",
	"license": "MIT",
	"require": {
		"php": ">=8.1"
	},
	"require-dev": {
		"phpunit/phpunit": "^10.5"
	},
	"autoload": {
		"files": [
			"functions.php"
		]
	},
	"autoload-dev": {
		"psr-4": {
			"QSortPhp\\Tests\\": "tests/"
		}
	},
	"scripts": {
		"test": "phpunit"
	},
	"config": {
		"sort-packages": true
	}
}
